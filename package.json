{
	"name": "obsidian-md2html-plugin",
	"version": "1.1.1",
	"description": "convert markdown to html inside obsidian (https://obsidian.md)",
	"main": "main.js",
	"scripts": {
		"postinstall": "patch-package",
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"md2html",
		"converter",
		"markdown to html"
	],
	"author": "",
	"license": "CC0",
	"devDependencies": {
		"@expressive-code/plugin-line-numbers": "^0.38.0",
		"@shikijs/transformers": "^1.22.2",
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"patch-package": "^8.0.0",
		"rehype-callout": "^0.1.0",
		"rehype-expressive-code": "^0.38.0",
		"rehype-format": "^5.0.1",
		"rehype-raw": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-expressive-code": "0.34.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.1",
		"shiki": "^1.22.2",
		"tslib": "2.4.0",
		"typescript": "4.7.4",
		"unified": "^11.0.5"
	}
}
